# —— 通义千问（DashScope OpenAI 兼容模式，由 Node 端 server.ts 读取）——
# 在项目根目录创建 .env（与 server.ts 同级），勿将真实 Key 提交到仓库
# AI_API_KEY=""
# AI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# AI_MODEL="qwen-turbo"
# 未配置 AI_API_KEY 时，聊天接口仍返回内置 mock 回复（便于离线演示）

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Live2D（官方 Hiyori / Rice / Haru，年轻二次元示例）---
# 资源：npm run fetch:live2d-official → public/live2d/{hiyori,rice,haru}_official/
# 不设 VITE_LIVE2D_MODEL_URL 时默认 Hiyori（见 src/live2d/defaultModelUrl.ts）
# 口型：ParamMouthOpenY + ParamMouthForm（Rice 无口形参数，嘴部几乎不动，见 rice_official/README.txt）
# VITE_LIVE2D_TALK_MOTION_GROUP 不设时代码默认 TapBody；设为 none 可关闭说话时额外动作

# —— ① Hiyori（默认，口型 + Idle / TapBody，无 Expressions）——
# VITE_LIVE2D_MODEL_URL="/live2d/hiyori_official/Hiyori.model3.json"
# VITE_LIVE2D_PARAM_OPEN="ParamMouthOpenY"
# VITE_LIVE2D_PARAM_FORM="ParamMouthForm"
# VITE_LIVE2D_IDLE_MOTION_GROUP="Idle"
# VITE_LIVE2D_TALK_MOTION_GROUP="TapBody"
# VITE_LIVE2D_TALK_MOTION_INDEX="0"

# —— ② Rice（Idle / TapBody；无口形参数，不推荐测口型）——
# VITE_LIVE2D_MODEL_URL="/live2d/rice_official/Rice.model3.json"
# VITE_LIVE2D_PARAM_OPEN="ParamMouthOpenY"
# VITE_LIVE2D_PARAM_FORM="ParamMouthForm"
# VITE_LIVE2D_IDLE_MOTION_GROUP="Idle"
# VITE_LIVE2D_TALK_MOTION_GROUP="TapBody"
# VITE_LIVE2D_TALK_MOTION_INDEX="0"

# —— ③ Haru（口型 + Idle / TapBody；Expressions 名 F01…F08）——
# VITE_LIVE2D_MODEL_URL="/live2d/haru_official/Haru.model3.json"
# VITE_LIVE2D_PARAM_OPEN="ParamMouthOpenY"
# VITE_LIVE2D_PARAM_FORM="ParamMouthForm"
# VITE_LIVE2D_IDLE_MOTION_GROUP="Idle"
# VITE_LIVE2D_TALK_MOTION_GROUP="TapBody"
# VITE_LIVE2D_TALK_MOTION_INDEX="0"
# VITE_LIVE2D_EXPRESSION_TALK="F03"
# VITE_LIVE2D_EXPRESSION_IDLE="F01"

# CosyVoice FastAPI（由 Node 端 server.ts 通过 dotenv 读取；把变量写在项目根目录的 .env）
# 不设 COSYVOICE_BASE_URL 时：仍返回对齐后的 viseme，但 useBrowserTts=true、audioUrl=null
# 接本地 CosyVoice 后，可在官方流程里用「音色克隆 / 更柔采样」得到更可爱的 spk_id，填到 COSYVOICE_SPK_ID
# COSYVOICE_BASE_URL="http://127.0.0.1:50000"
# COSYVOICE_SPK_ID="中文女"
# COSYVOICE_SAMPLE_RATE="22050"
